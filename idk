-- Chờ game tải xong
if not game:IsLoaded() then game.Loaded:Wait() end

-- Biến chặn để không bao giờ loop trong cùng một server
if _G.SignHandled then return end
_G.SignHandled = true

local player = game.Players.LocalPlayer

local function EquipAndFinish(char)
    local tool = nil
    local count = 0
    
    -- Thử tìm biển trong túi đồ (tối đa 5 giây)
    repeat
        tool = player.Backpack:FindFirstChild("Donation Sign")
        task.wait(0.5)
        count = count + 1
    until tool or count > 10

    if tool then
        tool.Parent = char
        print("✅ Đã cầm biển cho server này. Hệ thống dừng kiểm tra.")
    end
end

-- Thực hiện hành động duy nhất khi vào server
if player.Character then
    EquipAndFinish(player.Character)
else
    local connection
    connection = player.CharacterAdded:Connect(function(char)
        EquipAndFinish(char)
        connection:Disconnect() -- Tự hủy để mạng sau không cầm lại nữa
    end)
end
